"""Realizar un programa que sume los números ingresados por el usuario hasta que se
ingrese un 0. Al finalizar nos debe mostrar la suma por pantalla"""    


suma_total=0

while True:
    numero= int(input("Ingrese un numero (0 para terminar):"))
    if numero == 0:
        break
    suma_total +=numero
print(f"La suma total final es {suma_total}")     


"""Realizar un programa que pide al usuario su nombre y apellido y en el caso de no
estar la primera letra en mayúscula devolver el mismo nombre y apellido pero
con la primer letra en mayúscula"""

nombre= input("Ingrese su Nombre:")
apellido=input("Ingrese su apellido:")

if nombre[0].isupper() and apellido[0].isupper():
    estado="correcto" 

elif not nombre[0].isupper() and apellido[0].isupper():
    estado="ambos"

elif not nombre[0].isupper():
    estado="nombre"

else:
    estado="apellido"


match estado:

    case "correcto":
        print("Todo esta correcto",nombre, apellido)

    case "ambos":
        nombre= nombre[0].upper() + nombre[1:].lower()    
        apellido= apellido [0].upper() + apellido[1:].lower()
        print("Ambos corregidos", nombre, apellido)


    case "nombre":
        nombre= nombre[0].upper() + nombre[1:].lower()
        print("Nombre corregido", nombre, apellido)

    case "apellido":
        apellido= apellido [0].upper() + apellido[1:].lower()
        print("Apellido corregido", nombre, apellido)

    case __:
        print("Error inesperado")
        





"""Realizar un programa que pida al usuario su edad y nos diga si debe votar,
y en caso de tener entre 16 y 18. preguntar al usuario si decide votar o no"""


edad=int(input("Ingrese su edad:"))

if edad < 16:
    print("No puede votar")

elif edad >= 16 and 18:
    desicion= input("El voto es opcional. ¿Desea votar? (si/no)").lower()
    if desicion == "si":
        print("Usted decidio votar")
    else:
        print("Usted decidio no votar.")
else:
    print("Debe votar")       


